{
  "name": "@lifeos/db",
  "version": "0.0.0",
  "private": true,
  "description": "Prisma schema, migrations and typed client factory for LifeOS",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./prisma": "./prisma/schema.prisma"
  },
  "files": [
    "src",
    "prisma"
  ],
  "scripts": {
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:reset": "prisma migrate reset --force",
    "studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "pg:start": "tsx scripts/embedded-pg.ts",
    "typecheck": "tsc --noEmit",
    "build": "pnpm run generate",
    "codegen": "pnpm run generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts",
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.17.0"
  },
  "devDependencies": {
    "embedded-postgres": "18.3.0-beta.16",
    "prisma": "^5.17.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
