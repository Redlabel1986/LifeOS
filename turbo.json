{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [".env", "tsconfig.base.json"],
  "globalEnv": ["NODE_ENV", "CI"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "codegen"],
      "outputs": ["dist/**", ".nuxt/**", ".output/**", "src/generated/**"]
    },
    "codegen": {
      "inputs": ["schema.graphql", "codegen.yml", "**/*.graphql"],
      "outputs": ["src/generated/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build", "codegen"]
    },
    "test": {
      "dependsOn": ["^build", "codegen"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
