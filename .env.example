# ============================================================================
# LifeOS — example environment
# Copy to `.env` and fill secrets. Never commit real secrets.
# ============================================================================

NODE_ENV=development
LOG_LEVEL=debug

# --- API ---------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
WEB_PUBLIC_URL=http://localhost:3000

# --- PostgreSQL --------------------------------------------------------------
DATABASE_URL=postgresql://lifeos:lifeos@localhost:5432/lifeos

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Object storage (MinIO in dev, S3 in prod) -------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-central-1
S3_BUCKET=lifeos-documents
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- Auth (generate with: openssl rand -hex 32) ------------------------------
JWT_ACCESS_SECRET=replace_me_with_32_plus_random_chars_xxxxxxxx
JWT_REFRESH_SECRET=replace_me_with_different_32_plus_chars_yyyyy
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# --- Field-level encryption --------------------------------------------------
CRYPTO_MASTER_KEY=replace_me_with_32_plus_random_chars_zzzzzzzz

# --- AI / OCR ----------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OCR_PROVIDER=tesseract

# --- Banking (GoCardless Bank Account Data) ----------------------------------
# Free account: https://bankaccountdata.gocardless.com/user/signup/
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# --- Mail (MailHog in dev) ---------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=LifeOS <no-reply@lifeos.local>

# --- Feature flags -----------------------------------------------------------
FEATURE_BANK_IMPORT=false
FEATURE_EMAIL_PARSING=false
